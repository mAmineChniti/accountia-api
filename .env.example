# Database Configuration
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster0"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail SMTP)
GMAIL_USERNAME=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Server Configuration
PORT=4789
APP_HOST=localhost

# Application Configuration
APP_NAME=Accountia

# Environment
NODE_ENV=development

# Admin Platform Account (for initial setup)
ADMIN_EMAIL=admin@accountia.com
ADMIN_PASSWORD=CHANGE_ME

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4789/api/auth/google/callback"
GOOGLE_OAUTH_ALLOW_INSECURE_TLS="true"