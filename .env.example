# ============================================
# Required Configuration
# ============================================

# Database
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster0"

# JWT (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS, redirects, emails)
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail SMTP)
GMAIL_USERNAME=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ============================================
# Server Configuration (Optional)
# ============================================

PORT=4789
NODE_ENV=development
APP_NAME=Accountia

# ============================================
# Google OAuth (Optional - for Google login)
# ============================================

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4789/api/auth/google/callback
# Set to "true" only for local testing with self-signed certs
GOOGLE_OAUTH_ALLOW_INSECURE_TLS=false

# ============================================
# Groq AI Chat (Optional - for AI assistant)
# Get your API key at https://console.groq.com
# ============================================

GROQ_API_KEY=your-groq-api-key
# GROQ_MAX_COMPLETION_TOKENS=1200
# GROQ_TIMEOUT_MS=30000

# ============================================
# Stripe Payments (Optional - for invoice payments)
# ============================================

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# PAYMENT_METHOD_CONFIGURATION=pmc_...
STRIPE_FALLBACK_CURRENCY=tnd
STRIPE_FX_RATES=TND:0.32
MOCK_INVOICE_PAYMENTS=false
