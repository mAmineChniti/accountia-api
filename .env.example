# Database Configuration
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster0"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail SMTP)
GMAIL_USERNAME=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Server Configuration
PORT=4789
APP_HOST=localhost

# Application Configuration
APP_NAME=Accountia

# Environment
NODE_ENV=development

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# OpenRouter AI chat configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_MAX_COMPLETION_TOKENS=1200
OPENROUTER_TIMEOUT_MS=30000
GOOGLE_OAUTH_ALLOW_INSECURE_TLS="false" # Set to "true" only for local/dev testing with self-signed TLS certs
