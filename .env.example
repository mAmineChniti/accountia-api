# Database Configuration
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster0"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail SMTP)
GMAIL_USERNAME=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Server Configuration
PORT=4789
APP_HOST=localhost

# Application Configuration
APP_NAME=Accountia

# Environment
NODE_ENV=development

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# OpenRouter AI chat configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_MAX_COMPLETION_TOKENS=1200
OPENROUTER_TIMEOUT_MS=30000
GOOGLE_OAUTH_ALLOW_INSECURE_TLS="false" # Set to "true" only for local/dev testing with self-signed TLS certs

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# Optional: fallback Stripe checkout currency when invoice currency is unsupported by your Stripe account
STRIPE_FALLBACK_CURRENCY=usd
# Optional: conversion rates to fallback currency. Format: FROM:RATE,FROM2:RATE2 (e.g., TND:0.32 means 1 TND = 0.32 USD)
STRIPE_FX_RATES=TND:0.32
