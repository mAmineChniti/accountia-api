# Database Configuration
MONGO_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=Cluster0"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail SMTP)
GMAIL_USERNAME=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Server Configuration
PORT=4789
APP_HOST=localhost

# Application Configuration
APP_NAME=Accountia

# Environment
NODE_ENV=development

# Admin Platform Account
ADMIN_EMAIL=admin@accountia.com
ADMIN_PASSWORD=Admin@123456

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4789/api/auth/google/callback"
GOOGLE_OAUTH_ALLOW_INSECURE_TLS="true"

# Groq AI Configuration
GROQ_API_KEY="your-groq-api-key"
GROQ_MAX_COMPLETION_TOKENS=1200
GROQ_TIMEOUT_MS=30000

# Redis Configuration
REDIS_URL="rediss://<user>:<password>@<host>:<port>"

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_FALLBACK_CURRENCY=usd
STRIPE_FX_RATES=TND:0.32
MOCK_INVOICE_PAYMENTS=false

# AI Accountant Service
AI_ACCOUNTANT_URL=http://localhost:8000
AI_ACCOUNTANT_API_KEY=your-ai-accountant-api-key
